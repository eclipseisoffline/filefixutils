  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    {
      "name": "eclipseisoffline",
      "contact": {
        "homepage": "https://github.com/eclipseisoffline"
      }
    }
  ],
  "contact": {
    "homepage": "https://github.com/${github_repository}",
    "issues": "https://github.com/${github_repository}/issues",
